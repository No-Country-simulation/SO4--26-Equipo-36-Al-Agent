# APP CONFIGURATION
ENVIRONMENT=development
DEBUG=True
PROJECT_NAME="ConversaAI Analyzer"

# DATABASE (PostgreSQL)
# En Docker, el host es el nombre del servicio 'db' del docker-compose
POSTGRES_USER=conversa_user
POSTGRES_PASSWORD=conversa_pass
POSTGRES_DB=conversa_db
DATABASE_URL=postgresql://conversa_user:conversa_pass@db:5432/conversa_db

# PGADMIN (GUI de PostgreSQL)
PGADMIN_DEFAULT_EMAIL=admin@conversa.ai
PGADMIN_DEFAULT_PASSWORD=admin_pass

# AI & NLP (Groq & LangChain)
GROQ_API_KEY=gsk_tu_clave_aca
# Modelos sugeridos: llama-3.3-70b-versatile o mixtral-8x7b-32768
LLM_MODEL_NAME=llama-3.3-70b-versatile
CEREBRAS_API_KEY=tu_clave_de_cerebras_aca
CEREBRAS_MODEL_NAME=llama3.1-8b

# OBSERVABILITY (LangSmith)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=ls__tu_api_key_aca
LANGCHAIN_PROJECT="conversa-ai-project"



# CHROMADB (Vector Store para RAG)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# SECURITY
# Clave para firmar JWT u otros procesos de seguridad
SECRET_KEY=generar_un_string_muy_largo_y_seguro

# SMTP (Email para OTP)
# Para Gmail, usar un App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password_de_gmail
SMTP_FROM_EMAIL=tu_email@gmail.com

# SESSION MANAGEMENT
SESSION_TIMEOUT_SECONDS=300

# HUGGING FACE (Evaluator - Sentiment Analysis)
HF_API_TOKEN=hf_tu_token_de_hugging_face
HF_SENTIMENT_MODEL_ES=pysentimiento/robertuito-sentiment-analysis
HF_SENTIMENT_MODEL_PT=pysentimiento/bertweet-pt-sentiment
HF_API_TIMEOUT=30

# EVALUATOR PIPELINE
EVALUATOR_BATCH_SIZE=50
EVALUATOR_MAX_CONCURRENT=5